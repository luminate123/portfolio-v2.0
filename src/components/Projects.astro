---
const projects = [
    {
        title: "API de Detección de Fraude",
        description: "Es una API RESTful diseñada para identificar y prevenir phishing y smishing en comunicaciones digitales. Utilizando Inteligencia Artificial.",
        tags: ["Java 21", "Spring Boot 3.3", "Spring Security", "JWT", "PostgreSQL", "Maven"],
        gallery: ["API-fraud.png"],
        liveUrl: "https://github.com/luminate123/api-fraud-detection",
        featured: false,
    },
    {
        title: "KML Tech Solutions",
        description: "Sitio web corporativo desarrollado para la agencia KML Tech, enfocado en destacar su identidad, servicios y experiencia tecnológica.",
        tags: ["TypeScript", "React", "Tailwind", "Node.js"],
        gallery: ["KML-page.png"],
        liveUrl: "https://kml-tech.com/",
        featured: true,
    },
    {
        title: "Cliniderma Shop Test - KML Tech",
        description: "Plataforma de comercio electrónico omnicanal para productos dermatológicos. Destaca por su perfecta integración con Shopify y una robusta arquitectura backend construida en Nest.js.",
        tags: ["Next.js", "React", "Tailwind", "Nest.js", "Shopify", "TypeScript"],
        gallery: ["Cliniderma2.png", "Cliniderma3.png", "Cliniderma4.png"],
        liveUrl: "https://shop-test.kml-tech.com/",
        featured: false,
    },
    {
        title: "Cliniderma Test",
        description: "Sitio web especializado para clínica dermatológica. Incluye una interfaz optimizada para presentar el catálogo de tratamientos, testimonios de pacientes y opciones ágiles de contacto.",
        tags: ["TypeScript", "React", "Tailwind", "Node.js"],
        gallery: ["Cliniderma1.png"],
        liveUrl: "https://cliniderma-test.kml-tech.com/",
        featured: false,
    },
    {
        title: "Page Clinic Test",
        description: "Página web de alto rendimiento orientada a centros de salud. Cuenta con un diseño moderno e intuitivo, un listado detallado de servicios y formularios dinámicos para pacientes.",
        tags: ["TypeScript", "React", "Tailwind", "Node.js"],
        gallery: ["Maxilo1.png", "Maxilo2.png", "Maxilo3.png"],
        liveUrl: "https://page-clinic-test.kml-tech.com/",
        featured: false,
    },
    {
        title: "Website Doctor",
        description: "Portal profesional personalizado para la Dra. Diana Espinal. Diseñado para potenciar su marca médica mediante secciones dedicadas a su trayectoria, servicios ofrecidos y agendamiento de citas.",
        tags: ["TypeScript", "React", "Tailwind", "Node.js"],
        gallery: ["PageDraDiana.png"],
        liveUrl: "https://website-doctor.kml-tech.com/",
        featured: false,
    },
    {
        title: "Página web - Clinica Estetica",
        description: "Plataforma web elegante diseñada para el rubro de la estética. Su interfaz vanguardista resalta visualmente el catálogo de servicios y facilita la conversión mediante formularios rápidos.",
        tags: ["TypeScript", "React", "Tailwind", "Node.js"],
        gallery: ["Pagwebclinica.png", "clinica-especialidades.png", "clinica3.png"],
        liveUrl: "https://clinicstetic-test.kml-tech.com/",
        featured: true,
    },
    {
        title: "Tienda Online - Pokemon",
        description: "Aplicación interactiva de comercio electrónico para merchandising de Pokémon. Implementa un catálogo dinámico y un flujo completo y fluido para el carrito de compras.",
        tags: ["React", "Tailwind", "TypeScript"],
        gallery: ["poke-store1.png", "poke-store2.png", "poke-store3.png"],
        liveUrl: "https://pokemon-store-psi.vercel.app/",
        featured: true,
    }
];

// Collect all unique tags for filter buttons
const allTags = [...new Set(projects.flatMap(p => p.tags))].sort();

// Serialize projects to JSON for client-side filtering
const projectsJson = JSON.stringify(projects);
---

<!-- Section title -->
<div class="col-span-full flex items-center gap-4 py-4 animate-on-scroll" id="projects">
    <h2 class="text-2xl md:text-3xl font-bold text-white whitespace-nowrap">Proyectos</h2>
    <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
</div>

<!-- Filter Bar -->
<div class="col-span-full" id="projects-filters-wrapper">
    <div class="flex flex-wrap gap-2 items-center mb-6" id="projects-filters">
        <span class="text-[0.65rem] text-zinc-500 font-semibold uppercase tracking-widest mr-1">Filtrar</span>
        <button
            class="filter-btn active"
            data-filter="all"
        >
            Todos
        </button>
        {allTags.map(tag => (
            <button
                class="filter-btn"
                data-filter={tag}
            >
                {tag}
            </button>
        ))}
        <span class="ml-auto text-[0.65rem] text-zinc-500 tabular-nums" id="projects-count">
            {projects.length} proyectos
        </span>
    </div>
</div>

<!-- Bento Grid -->
<div
    class="col-span-full grid grid-cols-12 gap-4"
    id="projects-grid"
    data-projects={projectsJson}
>
    {projects.map((project, index) => (
        <article
            class="project-card"
            data-tags={JSON.stringify(project.tags)}
            data-index={index}
            data-gallery={JSON.stringify(project.gallery)}
            data-title={project.title}
            style={`grid-column: span ${index % 3 === 0 ? 7 : 5}`}
        >
            <!-- Carousel -->
            <div class="card-carousel" data-carousel={index}>
                <div class="carousel-track">
                    {project.gallery.map((src, i) => (
                        <img
                            src={src}
                            alt={`${project.title} - ${i + 1}`}
                            loading="lazy"
                            class={`carousel-slide ${i === 0 ? 'active' : ''}`}
                            data-slide={i}
                        />
                    ))}
                </div>
                <!-- Arrows -->
                {project.gallery.length > 1 && (
                    <>
                        <button class="carousel-btn carousel--prev" data-dir="-1" aria-label="Anterior">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        </button>
                        <button class="carousel-btn carousel-next" data-dir="1" aria-label="Siguiente">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        </button>
                        <div class="carousel-dots">
                            {project.gallery.map((_src, i) => (
                                <button class={`carousel-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Imagen ${i + 1}`} />
                            ))}
                        </div>
                    </>
                )}
                <div class="carousel-counter">
                    <span data-current>1</span> / <span>{project.gallery.length}</span>
                </div>
            </div>

            <!-- Info -->
            <div class="card-info">
                <div class="flex items-center gap-2 flex-wrap mb-2">
                    {project.featured && (
                        <span class="badge-featured">Featured</span>
                    )}
                    <span class="text-[0.65rem] text-zinc-600 font-mono">0{index + 1}</span>
                </div>
                <h3 class="text-base md:text-lg font-bold text-white leading-snug mb-2">{project.title}</h3>
                <p class="text-xs text-zinc-400 leading-relaxed mb-4 line-clamp-2">{project.description}</p>
                <div class="flex flex-wrap gap-1.5 mb-4">
                    {project.tags.map(tag => (
                        <span class="tag-pill" data-tag={tag}>{tag}</span>
                    ))}
                </div>
                {project.liveUrl && (
                    <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                        Ver proyecto
                    </a>
                )}
            </div>
        </article>
    ))}
</div>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay" aria-hidden="true">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-content">
        <div class="lightbox-header">
            <h3 id="lightbox-title" class="text-base font-semibold text-white truncate"></h3>
            <div class="flex items-center gap-3 shrink-0">
                <span id="lightbox-counter" class="text-xs text-zinc-400 font-mono"></span>
                <button id="lightbox-close" class="lightbox-close-btn" aria-label="Cerrar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
        </div>
        <div class="lightbox-image-wrapper">
            <button id="lightbox-prev" class="lightbox-nav lightbox-nav-prev" aria-label="Anterior">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <img id="lightbox-img" src="" alt="" class="lightbox-image" />
            <button id="lightbox-next" class="lightbox-nav lightbox-nav-next" aria-label="Siguiente">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
        </div>
    </div>
</div>

<style>
    /* =====================
       Filter Buttons
       ===================== */
    .filter-btn {
        padding: 0.3rem 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: transparent;
        color: #71717a;
        font-size: 0.72rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
        font-family: inherit;
    }
    .filter-btn:hover {
        border-color: rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.8);
    }
    .filter-btn.active {
        background: rgba(59, 130, 246, 0.12);
        border-color: rgba(59, 130, 246, 0.35);
        color: #93c5fd;
    }

    /* =====================
       Bento Card
       ===================== */
    .project-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 1.25rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
            border-color 0.35s ease,
            box-shadow 0.35s ease,
            opacity 0.4s ease,
            transform 0.4s ease;
        position: relative;
    }
    .project-card:hover {
        border-color: rgba(255, 255, 255, 0.13);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(59, 130, 246, 0.04);
    }
    .project-card.is-hidden {
        opacity: 0;
        transform: scale(0.96) translateY(8px);
        pointer-events: none;
        position: absolute;
        visibility: hidden;
    }
    .project-card.is-entering {
        animation: cardEnter 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    @keyframes cardEnter {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* =====================
       Carousel inside card
       ===================== */
    .card-carousel {
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: #0a0a0f;
        flex-shrink: 0;
    }
    .carousel-track { position: relative; width: 100%; height: 100%; }
    .carousel-slide {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        opacity: 0;
        transition: opacity 0.55s ease, transform 0.55s ease;
        transform: scale(1.03);
    }
    .carousel-slide.active { opacity: 1; transform: scale(1); }

    .carousel-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        cursor: pointer;
        z-index: 3;
        opacity: 0;
        transition: all 0.25s ease;
        backdrop-filter: blur(6px);
    }
    .card-carousel:hover .carousel-btn { opacity: 1; }
    .carousel-btn:hover {
        background: rgba(59, 130, 246, 0.45);
        border-color: rgba(59, 130, 246, 0.6);
    }
    .carousel--prev { left: 0.6rem; }
    .carousel-next  { right: 0.6rem; }

    .carousel-dots {
        position: absolute;
        bottom: 0.6rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 0.35rem;
        z-index: 3;
    }
    .carousel-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        border: none;
        cursor: pointer;
        padding: 0;
        transition: all 0.25s ease;
    }
    .carousel-dot.active {
        background: #3b82f6;
        width: 18px;
        border-radius: 999px;
    }
    .carousel-counter {
        position: absolute;
        top: 0.6rem;
        right: 0.6rem;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(6px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        font-size: 0.65rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.65);
        z-index: 3;
        font-variant-numeric: tabular-nums;
    }

    /* =====================
       Card Info
       ===================== */
    .card-info {
        padding: 1.1rem 1.25rem 1.25rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    .badge-featured {
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.12);
        border: 1px solid rgba(59, 130, 246, 0.25);
        font-size: 0.6rem;
        font-weight: 700;
        color: #93c5fd;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .tag-pill {
        padding: 0.22rem 0.55rem;
        font-size: 0.65rem;
        font-weight: 500;
        border-radius: 0.45rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: #a1a1aa;
        transition: all 0.2s ease;
    }
    .tag-pill.is-active-tag {
        background: rgba(59, 130, 246, 0.1);
        border-color: rgba(59, 130, 246, 0.22);
        color: #93c5fd;
    }
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.5rem 1rem;
        border-radius: 0.7rem;
        font-size: 0.78rem;
        font-weight: 600;
        text-decoration: none;
        background: linear-gradient(135deg, rgba(59,130,246,0.18), rgba(139,92,246,0.12));
        border: 1px solid rgba(59, 130, 246, 0.28);
        color: #93c5fd;
        transition: all 0.25s ease;
        width: fit-content;
        margin-top: auto;
    }
    .btn-primary:hover {
        background: linear-gradient(135deg, rgba(59,130,246,0.3), rgba(139,92,246,0.22));
        border-color: rgba(59, 130, 246, 0.5);
        color: #bdd4fd;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
    }

    /* =====================
       Grid responsive
       ===================== */
    @media (max-width: 768px) {
        #projects-grid {
            grid-template-columns: 1fr !important;
        }
        .project-card {
            grid-column: span 1 !important;
        }
    }

    /* =====================
       Lightbox
       ===================== */
    .lightbox-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .lightbox-overlay.active {
        opacity: 1;
        pointer-events: all;
    }
    .lightbox-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(18px);
    }
    .lightbox-content {
        position: relative;
        width: 92vw;
        max-width: 1100px;
        max-height: 92vh;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        transform: scale(0.93) translateY(14px);
        transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .lightbox-overlay.active .lightbox-content {
        transform: scale(1) translateY(0);
    }
    .lightbox-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 0.25rem;
        gap: 1rem;
    }
    .lightbox-close-btn {
        width: 38px; height: 38px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 0.7rem;
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #a1a1aa;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .lightbox-close-btn:hover {
        background: rgba(239, 68, 68, 0.18);
        border-color: rgba(239, 68, 68, 0.3);
        color: #fca5a5;
    }
    .lightbox-image-wrapper {
        position: relative;
        height: 75vh;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1rem;
        overflow: hidden;
        background: #08080c;
        border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .lightbox-image {
        max-width: 100%; max-height: 100%;
        width: auto; height: auto;
        object-fit: contain;
        transition: opacity 0.3s ease;
    }
    .lightbox-image.loading { opacity: 0.15; }
    .lightbox-nav {
        position: absolute;
        top: 50%; transform: translateY(-50%);
        width: 46px; height: 46px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white; cursor: pointer;
        transition: all 0.2s ease;
        backdrop-filter: blur(8px);
        z-index: 2;
    }
    .lightbox-nav:hover {
        background: rgba(59, 130, 246, 0.4);
        border-color: rgba(59, 130, 246, 0.55);
        transform: translateY(-50%) scale(1.07);
    }
    .lightbox-nav-prev { left: 1rem; }
    .lightbox-nav-next { right: 1rem; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        // =====================
        // FILTER LOGIC
        // =====================
        const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
        const cards = document.querySelectorAll<HTMLElement>('.project-card');
        const countEl = document.getElementById('projects-count');
        const grid = document.getElementById('projects-grid');
        let activeFilter = 'all';

        function packSpans(items: HTMLElement[]): number[] {
            // Assign col spans so every row sums to 12, no gaps
            // Pattern per position in row: 7, 5, 7, 5...
            const spans: number[] = [];
            let col = 0;
            for (let i = 0; i < items.length; i++) {
                const remaining = 12 - col;
                const isLast = i === items.length - 1;

                if (isLast && remaining > 0) {
                    // Last item takes whatever is left (fills the row)
                    spans.push(remaining);
                    col = 0;
                } else if (col === 0) {
                    // Start of row: alternate 7 / 5 based on row index
                    const rowIndex = Math.floor(spans.length / 2);
                    const span = rowIndex % 2 === 0 ? 7 : 5;
                    spans.push(span);
                    col += span;
                    if (col >= 12) col = 0;
                } else {
                    // Fill rest of row
                    spans.push(remaining);
                    col = 0;
                }
            }
            return spans;
        }

        function applyFilter(filter: string) {
            activeFilter = filter;

            // Update button states
            filterBtns.forEach(btn => {
                btn.classList.toggle('active', btn.dataset.filter === filter);
            });

            // Determine visible cards
            const visible: HTMLElement[] = [];
            cards.forEach(card => {
                const tags: string[] = JSON.parse(card.dataset.tags || '[]');
                const show = filter === 'all' || tags.includes(filter);
                if (show) visible.push(card);
            });

            // Calculate spans for visible cards
            const spans = packSpans(visible);

            // Apply spans and visibility
            let visibleIdx = 0;
            cards.forEach(card => {
                const tags: string[] = JSON.parse(card.dataset.tags || '[]');
                const show = filter === 'all' || tags.includes(filter);

                if (show) {
                    const span = spans[visibleIdx];
                    card.style.gridColumn = `span ${span}`;
                    card.classList.remove('is-hidden');
                    card.classList.add('is-entering');
                    card.style.animationDelay = `${visibleIdx * 0.055}s`;

                    // Highlight matching tags
                    card.querySelectorAll<HTMLElement>('.tag-pill').forEach(pill => {
                        const tagName = pill.dataset.tag || '';
                        pill.classList.toggle('is-active-tag', filter !== 'all' && tagName === filter);
                    });

                    visibleIdx++;
                } else {
                    card.classList.add('is-hidden');
                    card.classList.remove('is-entering');
                    card.style.gridColumn = 'span 0';
                }
            });

            // Update count
            if (countEl) {
                countEl.textContent = `${visible.length} proyecto${visible.length !== 1 ? 's' : ''}`;
            }
        }

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                applyFilter(btn.dataset.filter || 'all');
            });
        });

        // Initial span assignment
        applyFilter('all');

        // =====================
        // CAROUSELS
        // =====================
        document.querySelectorAll<HTMLElement>('.card-carousel').forEach(carousel => {
            const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide');
            const dots   = carousel.querySelectorAll<HTMLElement>('.carousel-dot');
            const counter = carousel.querySelector<HTMLElement>('[data-current]');
            const btnPrev = carousel.querySelector<HTMLButtonElement>('.carousel--prev');
            const btnNext = carousel.querySelector<HTMLButtonElement>('.carousel-next');
            let current = 0;
            let timer: ReturnType<typeof setInterval> | null = null;

            function goTo(i: number) {
                if (i < 0) i = slides.length - 1;
                if (i >= slides.length) i = 0;
                slides[current]?.classList.remove('active');
                dots[current]?.classList.remove('active');
                current = i;
                slides[current]?.classList.add('active');
                dots[current]?.classList.add('active');
                if (counter) counter.textContent = String(current + 1);
            }

            function start() {
                stop();
                if (slides.length > 1) timer = setInterval(() => goTo(current + 1), 4500);
            }
            function stop() {
                if (timer) { clearInterval(timer); timer = null; }
            }

            btnPrev?.addEventListener('click', e => { e.stopPropagation(); goTo(current - 1); start(); });
            btnNext?.addEventListener('click', e => { e.stopPropagation(); goTo(current + 1); start(); });
            dots.forEach((dot, i) => dot.addEventListener('click', e => { e.stopPropagation(); goTo(i); start(); }));
            carousel.addEventListener('mouseenter', stop);
            carousel.addEventListener('mouseleave', start);

            // Touch swipe
            let tx = 0;
            carousel.addEventListener('touchstart', e => { tx = (e as TouchEvent).changedTouches[0].screenX; stop(); }, { passive: true });
            carousel.addEventListener('touchend', e => {
                const diff = tx - (e as TouchEvent).changedTouches[0].screenX;
                if (Math.abs(diff) > 45) goTo(diff > 0 ? current + 1 : current - 1);
                start();
            }, { passive: true });

            start();
        });

        // =====================
        // LIGHTBOX
        // =====================
        const lightbox = document.getElementById('lightbox')!;
        const lbImg    = document.getElementById('lightbox-img') as HTMLImageElement;
        const lbTitle  = document.getElementById('lightbox-title')!;
        const lbCounter = document.getElementById('lightbox-counter')!;
        const btnClose = document.getElementById('lightbox-close')!;
        const btnPrevLb = document.getElementById('lightbox-prev')!;
        const btnNextLb = document.getElementById('lightbox-next')!;

        let lbGallery: string[] = [];
        let lbIdx = 0;

        function openLb(gallery: string[], title: string, start = 0) {
            lbGallery = gallery; lbIdx = start;
            lbTitle.textContent = title;
            showLbImg(lbIdx);
            lightbox.classList.add('active');
            lightbox.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }
        function closeLb() {
            lightbox.classList.remove('active');
            lightbox.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }
        function showLbImg(i: number) {
            if (i < 0) i = lbGallery.length - 1;
            if (i >= lbGallery.length) i = 0;
            lbIdx = i;
            lbImg.classList.add('loading');
            lbImg.src = lbGallery[i];
            lbImg.onload = () => lbImg.classList.remove('loading');
            lbCounter.textContent = `${i + 1} / ${lbGallery.length}`;
        }

        document.querySelectorAll<HTMLElement>('.card-carousel').forEach(carousel => {
            carousel.addEventListener('click', e => {
                const target = e.target as HTMLElement;
                if (!target.classList.contains('carousel-slide')) return;
                const card = carousel.closest<HTMLElement>('.project-card');
                if (!card) return;
                const gallery: string[] = JSON.parse(card.dataset.gallery || '[]');
                const title = card.dataset.title || '';
                const idx = parseInt(target.dataset.slide || '0');
                if (gallery.length) openLb(gallery, title, idx);
            });
        });

        btnClose.addEventListener('click', closeLb);
        document.querySelector('.lightbox-backdrop')?.addEventListener('click', closeLb);
        btnPrevLb.addEventListener('click', () => showLbImg(lbIdx - 1));
        btnNextLb.addEventListener('click', () => showLbImg(lbIdx + 1));
        document.addEventListener('keydown', e => {
            if (!lightbox.classList.contains('active')) return;
            if (e.key === 'Escape')      closeLb();
            if (e.key === 'ArrowLeft')   showLbImg(lbIdx - 1);
            if (e.key === 'ArrowRight')  showLbImg(lbIdx + 1);
        });
    });
</script>